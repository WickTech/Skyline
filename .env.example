# Copy this file to ".env" and fill in your own key.
# CRA only exposes variables prefixed with REACT_APP_ to the browser, and bakes
# them in at BUILD time — set the same variable in your Vercel project settings.

# OpenWeatherMap — https://openweathermap.org/api
# One free key powers current weather, 5-day forecast, geocoding, air pollution
# and the map tile layers. Weather alerts additionally need the (also free) One
# Call API 3.0 subscription enabled on your account — the app degrades
# gracefully without it.
REACT_APP_OPENWEATHER_KEY=your_openweathermap_key_here

# No key needed: Open-Meteo (hourly + UV), RainViewer (radar), OpenStreetMap.
