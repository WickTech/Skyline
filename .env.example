# Copy this file to ".env" and fill in your own keys.
# CRA only exposes variables prefixed with REACT_APP_ to the browser.

# OpenWeatherMap — https://openweathermap.org/api  (free "Current Weather" + "5 day / 3 hour forecast")
REACT_APP_OPENWEATHER_KEY=your_openweathermap_key_here

# World Air Quality Index (WAQI) — https://aqicn.org/data-platform/token/
REACT_APP_WAQI_TOKEN=your_waqi_token_here
